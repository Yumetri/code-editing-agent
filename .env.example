# Copy this file to .env and replace placeholders with real API keys.

# Provider selection: openrouter is the default.
# With LLM_PROVIDER=openrouter, the app tries OpenRouter first.
# If OpenRouter is missing a key or authentication fails, it falls back to Gemini.
# Use LLM_PROVIDER=gemini only when you want to bypass OpenRouter entirely.
LLM_PROVIDER=openrouter

# OpenRouter primary provider. This is tried first by default.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_NAME=poolside/laguna-m.1:free

# Gemini fallback provider for OpenRouter authentication failures.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash

# Optional app logging level: DEBUG, INFO, WARNING, ERROR.
# WARNING hides normal HTTP request logs; use INFO only when debugging provider flow.
LOG_LEVEL=WARNING
